> type pair = { x : int; y : int }
> let p = { x = 1; y = 2 }
> p.x
1
> p.y
2
> let q = { name = "add"; arity = 2; result = Some 42 }
> print_endline q.name
add
> q.arity + (match q.result with Some n -> n | None -> 0)
44
> let nested = { outer = p; label = "point" }
> let outer = nested.outer in outer.x + outer.y3
